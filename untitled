// ---------------------------
// BFS distance (16 rooms)
// ---------------------------
int distanceBetween(int start, int target) {
  if (start == target) return 0;

  bool visited[16] = {false};
  int queue[16];
  int dist[16];

  int head = 0, tail = 0;

  queue[tail] = start;
  dist[start] = 0;
  visited[start] = true;
  tail++;

  while (head < tail) {
    int r = queue[head++];
    for (int d = 0; d < 4; d++) {
      int next = exits[r][d];
      if (next != -1 && !visited[next]) {
        visited[next] = true;
        dist[next] = dist[r] + 1;
        queue[tail++] = next;
        if (next == target) return dist[next];
      }
    }
  }
  return 99; // unreachable
}

// ---------------------------
// Push creature back by +2 distance
// ---------------------------
void pushCreatureBack() {
  int currentDist = distanceBetween(playerRoom, creatureRoom);
  int targetDist = currentDist + 2;

  int candidates[16];
  int count = 0;

  for (int r = 0; r < 16; r++) {
    int d = distanceBetween(playerRoom, r);
    if (d == targetDist) {
      candidates[count++] = r;
    }
  }

  if (count > 0) {
    creatureRoom = candidates[rand() % count];
    return;
  }

  int bestRoom = creatureRoom;
  int bestDist = currentDist;

  for (int r = 0; r < 16; r++) {
    int d = distanceBetween(playerRoom, r);
    if (d > bestDist) {
      bestDist = d;
      bestRoom = r;
    }
  }

  creatureRoom = bestRoom;
}

// ---------------------------
// Creature movement
// ---------------------------
void moveCreature() {

  if (creatureConfused > 0) {
    creatureConfused--;

    int options[4];
    int count = 0;

    for (int d = 0; d < 4; d++) {
      if (exits[creatureRoom][d] != -1) {
        options[count++] = exits[creatureRoom][d];
      }
    }

    if (count > 0) {
      creatureRoom = options[rand() % count];
    }

    return;
  }

  int bestRoom = creatureRoom;
  int bestDist = distanceBetween(creatureRoom, playerRoom);

  for (int d = 0; d < 4; d++) {
    int next = exits[creatureRoom][d];
    if (next != -1) {
      int dist = distanceBetween(next, playerRoom);
      if (dist < bestDist) {
        bestDist = dist;
        bestRoom = next;
      }
    }
  }

  if (bestRoom != creatureRoom) {
    creatureRoom = bestRoom;
  } else {
    int options[4];
    int count = 0;
    for (int d = 0; d < 4; d++) {
      if (exits[creatureRoom][d] != -1) {
        options[count++] = exits[creatureRoom][d];
      }
    }
    if (count > 0) {
      creatureRoom = options[rand() % count];
    }
  }
}

// ---------------------------
// Sound cues
// ---------------------------
void soundCue() {
  int dist = distanceBetween(playerRoom, creatureRoom);

  if (dist == 0) {
    std::cout << "You hear breathing right behind you...\n";
  } else if (dist == 1) {
    std::cout << "Footsteps echo nearby.\n";
  } else if (dist == 2) {
    std::cout << "A faint thump in the distance.\n";
  } else {
    std::cout << "Silence... too much silence.\n";
  }
}

// ---------------------------
// Map generation (16 rooms)
// ---------------------------
void generateMap() {

  // Clear grid
  for (int y = 0; y < 4; y++)
    for (int x = 0; x < 4; x++)
      grid[y][x] = -1;

  // Randomly place rooms 0–15
  int used = 0;
  while (used < 16) {
    int x = rand() % 4;
    int y = rand() % 4;
    if (grid[y][x] == -1) {
      grid[y][x] = used;
      used++;
    }
  }

  // Clear exits
  for (int i = 0; i < 16; i++)
    for (int d = 0; d < 4; d++)
      exits[i][d] = -1;

  // Build exits (N, S, E, W)
  for (int y = 0; y < 4; y++) {
    for (int x = 0; x < 4; x++) {
      int r = grid[y][x];
      if (r == -1) continue;

      if (y > 0 && grid[y - 1][x] != -1) exits[r][0] = grid[y - 1][x]; // north
      if (y < 3 && grid[y + 1][x] != -1) exits[r][1] = grid[y + 1][x]; // south
      if (x < 3 && grid[y][x + 1] != -1) exits[r][2] = grid[y][x + 1]; // east
      if (x > 0 && grid[y][x - 1] != -1) exits[r][3] = grid[y][x - 1]; // west
    }
  }

  // Reset searched flags
  for (int i = 0; i < 16; i++)
    searched[i] = false;

  // Place player
  while (true) {
    int x = rand() % 4;
    int y = rand() % 4;
    int r = grid[y][x];
    if (r != -1 && roomNames[r] != "Exit Door") {
      playerRoom = r;
      break;
    }
  }

  // Place creature
  while (true) {
    int x = rand() % 4;
    int y = rand() % 4;
    int r = grid[y][x];
    if (r != -1 && r != playerRoom && roomNames[r] != "Exit Door") {
      creatureRoom = r;
      break;
    }
  }
}

// ---------------------------
// Room description
// ---------------------------
void describeRoom() {
  std::cout << "\n--------------------------------\n";
  std::cout << "You are in the " << roomNames[playerRoom] << "\n";
  std::cout << roomDesc[playerRoom] << "\n";
  std::cout << "--------------------------------\n";

  soundCue();
}
// ---------------------------
// Setup  →  main() START
// ---------------------------
int main() {

  // Arduino: Serial.begin(9600);
  // C++: no setup needed for std::cout

  // Arduino: randomSeed(analogRead(0));
  // C++ equivalent:
  std::srand(std::time(nullptr));

  std::cout << "What Lives Below — ORIGINAL 16 ROOM EDITION\n";
  std::cout << "Commands: north/south/east/west, hide, unhide, search, inventory\n";

  generateMap();
  describeRoom();
  // ---------------------------
  // Loop  →  while(true)
  // ---------------------------
  while (true) {

    // Arduino: if (!Serial.available()) return;
    // C++: just read a line when ready
    std::string cmd;
    if (!std::getline(std::cin, cmd)) continue;

    // trim whitespace
    cmd.erase(0, cmd.find_first_not_of(" \t\r\n"));
    cmd.erase(cmd.find_last_not_of(" \t\r\n") + 1);

    // lowercase
    std::transform(cmd.begin(), cmd.end(), cmd.begin(), ::tolower);

    // remove carriage returns
    cmd.erase(std::remove(cmd.begin(), cmd.end(), '\r'), cmd.end());

    // Shortcuts
    if (cmd == "n") cmd = "north";
    if (cmd == "s") cmd = "south";
    if (cmd == "e") cmd = "east";
    if (cmd == "w") cmd = "west";

    // INVENTORY
    if (cmd == "inventory") {
      std::cout << "\nInventory:\n";
      if (hasFlashlight) std::cout << "- Flashlight\n";
      if (hasBattery) std::cout << "- Battery\n";
      if (hasKeycard) std::cout << "- Keycard\n";
      if (hasGenerator) std::cout << "- Generator\n";
      if (hasMedkit) std::cout << "- Medkit\n";
      if (!hasFlashlight && !hasBattery && !hasKeycard && !hasMedkit && !hasGenerator)
        std::cout << "(empty)\n";
      continue;
    }

    // HIDE
    if (cmd == "hide") {
      if (hiding) {
        std::cout << "You are already hiding.\n";
      } else {
        hiding = true;
        creatureConfused = 2;
        std::cout << "You slip into the shadows...\n";
        pushCreatureBack();
      }
      describeRoom();
      continue;
    }

    // UNHIDE
    if (cmd == "unhide") {
      if (!hiding) {
        std::cout << "You are not hiding.\n";
      } else {
        hiding = false;
        std::cout << "You step out of hiding...\n";
      }
      moveCreature();
      describeRoom();
      continue;
    }

    // SEARCH
    if (cmd == "search") {

      // SPECIAL: Generator Room event
      if (roomNames[playerRoom] == "Generator Room" && !generatorFixed) {
        std::cout << "You inspect the generator...\n";
        std::this_thread::sleep_for(std::chrono::milliseconds(400));
        std::cout << "You manage to restore partial power to the facility.\n";
        generatorFixed = true;
        moveCreature();
        moveCreature();
        describeRoom();
        continue;
      }

      if (hiding) {
        std::cout << "You can't search while hiding.\n";
      } else if (searched[playerRoom]) {
        std::cout << "You've already searched this room.\n";
      } else {
        searched[playerRoom] = true;

        std::cout << "You search the room...\n";
        std::cout << "The noise echoes loudly.\n";

        int roll = rand() % 100;

        if (roll < 20) {
          std::cout << "You found a Flashlight!\n";
          hasFlashlight = true;
        } else if (roll < 40) {
          std::cout << "You found a Battery!\n";
          hasBattery = true;
        } else if (roll < 50) {
          std::cout << "You found a Keycard!\n";
          hasKeycard = true;
        } else if (roll < 55) {
          std::cout << "You found a Generator!\n";
          hasGenerator = true;
        } else if (roll < 70) {
          std::cout << "You found a Medkit!\n";
          hasMedkit = true;
        } else {
          std::cout << "You found nothing.\n";
        }

        moveCreature();
        moveCreature();
      }

      // DEATH CHECK
      if (creatureRoom == playerRoom && !hiding) {
        goto deathScreen;
      }

      // ESCAPE CHECK
      if (roomNames[playerRoom] == "Exit Door" && hasKeycard) {
        goto escapeScreen;
      }
      if (roomNames[playerRoom] == "Comms Room" && hasGenerator) {
        goto commsBadEnd;
      }

      describeRoom();
      continue;
    }

    // BLOCK MOVEMENT WHILE HIDING
    if (hiding && (cmd == "north" || cmd == "south" || cmd == "east" || cmd == "west")) {
      std::cout << "You can't move while hiding.\n";
      moveCreature();
      describeRoom();
      continue;
    }

    // MOVEMENT
    int nextRoom = -1;

    if (cmd == "north") nextRoom = exits[playerRoom][0];
    else if (cmd == "south") nextRoom = exits[playerRoom][1];
    else if (cmd == "east")  nextRoom = exits[playerRoom][2];
    else if (cmd == "west")  nextRoom = exits[playerRoom][3];
    else {
      std::cout << "Invalid command.\n";
      continue;
    }

    if (nextRoom == -1) {
      std::cout << "You can't go that way.\n";
    } else {
      playerRoom = nextRoom;
    }

    // CREATURE MOVES
    moveCreature();

    // DEATH CHECK
    if (creatureRoom == playerRoom && !hiding) {
      goto deathScreen;
    }

    // ESCAPE CHECK
    if (roomNames[playerRoom] == "Exit Door" && hasKeycard) {
      goto escapeScreen;
    }
    if (roomNames[playerRoom] == "Exit Door" && hasKeycard) {
      goto commsBadEnd;
    }

    describeRoom();
    continue;

    // ---------------------------
    // DEATH SCREEN
    // ---------------------------
deathScreen:
    std::cout << "\n--------------------------------\n";
    std::cout << "The creature lunges from the darkness behind you...\n";
    std::cout << "You feel its claws tear into you.\n";
    std::cout << "Everything fades.\n";
    std::cout << "          DEvOurEd\n";
    std::cout << "           YOU DIED\n";
    std::cout << "--------------------------------\n";
    while (true);

    // ---------------------------
    // ESCAPE SCREEN
    // ---------------------------
escapeScreen:
    std::cout << "\n--------------------------------\n";
    std::cout << "You swipe the keycard. The lock clicks open.\n";
    std::cout << "With a final glance back into the darkness,\n";
    std::cout << "you step through the door and slam it behind you.\n";
    std::cout << "For now, at least...\n";
    std::cout << "           YOU ESCAPED\n";
    std::cout << "--------------------------------\n";
    while (true);

    // ---------------------------
    // BAD COMMS ENDING
    // ---------------------------
commsBadEnd:
    std::cout << "\n---------------------------------------------------------------\n";
    std::cout << "You manage to fix the communication equipment\n";
    std::cout << "You try to communicate with the people outside\n";
    std::cout << "Then the creature SLAMS into the room before you can react.\n";
    std::cout << "Your desperate call for help was the last sound you ever made.\n";
    std::cout << "           dEvoUreD\n";
    std::cout << "       The End, Comms ending\n";
    std::cout << "-----------------------------------------------------------------\n";
    while (true);

  } // end while(true)

} // end main()
